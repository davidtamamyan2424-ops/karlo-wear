// Prisma schema for Karlo Wear
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String        @id @default(cuid())
  sku         String        @unique // Артикул
  name        String
  description String?
  price       Int // в копейках (minor units)
  currency    String        @default("RUB")
  imageUrl    String? // основное изображение (обложка)
  imagesJson  String? // JSON-массив URL изображений для галереи
  sizeChartUrl String? // размерная сетка (отдельно от фото товара)
  category    String?
  // Бейдж витрины: NEW | BESTSELLER | LIMITED (необязательно)
  badge       String?
  // Характеристики
  composition   String? // Состав, напр. «100% хлопок»
  fabricDensity String? // Плотность ткани, напр. «240 г/м²»
  // Параметры модели на фото
  modelHeight Int? // Рост модели, см
  modelSize   String? // Размер на модели: S | M | L | XL
  isActive    Boolean       @default(true)
  archived    Boolean       @default(false)
  // Позиция в каталоге (управляется администратором, сортировка по возрастанию).
  position    Int           @default(0)
  // Себестоимость единицы (копейки, не показывается покупателям)
  unitCost       Int           @default(0)
  sizes       ProductSize[]
  variants    ProductVariant[]
  orderItems  OrderItem[]
  manualSales ManualSale[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductSize {
  id        String      @id @default(cuid())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  label     String // только S | M | L | XL
  stock     Int         @default(0) // остаток по размеру
  orderItems OrderItem[]

  @@unique([productId, label])
}

model ProductVariant {
  id         String               @id @default(cuid())
  product    Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  name       String
  sku        String               @unique
  colorHex   String? // цвет для превью на витрине (#RRGGBB)
  price      Int?
  imageUrl   String?
  imagesJson String?
  position   Int                  @default(0)
  isDefault  Boolean              @default(false)
  sizes      ProductVariantSize[]
  orderItems OrderItem[]
  manualSales ManualSale[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([productId, name])
}

model ProductVariantSize {
  id         String         @id @default(cuid())
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId  String
  label      String
  stock      Int            @default(0)
  orderItems OrderItem[]
  manualSales ManualSale[]

  @@unique([variantId, label])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int         @unique // человекочитаемый номер заказа (Заказ №XXX)
  // Telegram identity of the buyer
  telegramId    String?
  telegramUser  String? // Telegram username
  // Checkout form fields
  customerName  String // Имя
  phone         String // Телефон
  city          String // Город
  comment       String? // Комментарий к заказу
  // Статус заказа (см. ORDER_STATUSES в src/constants.ts; храним строкой).
  status        String      @default("AWAITING_PAYMENT")
  totalAmount   Int
  currency      String      @default("RUB")
  // Назначенный банк — фиксируется при создании заказа и больше не меняется.
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  paymentAccountId String?
  assignedBankName      String?
  assignedRecipientName String?
  assignedPhoneNumber   String?
  // Доставка (стоимость рассчитывается вручную после оформления, не на чекауте).
  deliveryMethod    String? // WILDBERRIES | OZON | OTHER
  deliveryAddress   String? // Адрес пункта выдачи / адрес доставки
  deliveryComment   String? // Номер ПВЗ или предпочтительный способ (для «Другое»)
  deliveryConfirmed Boolean @default(false) // Покупатель подтвердил уведомление о доставке
  // Срок, до которого заказ должен быть оплачен (иначе авто-отмена).
  paymentDueAt  DateTime?
  // Был ли восстановлен резерв склада (защита от повторного восстановления).
  stockRestored Boolean     @default(false)
  items         OrderItem[]
  paymentProofs PaymentProof[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PaymentAccount {
  id            String   @id @default(cuid())
  bankName      String
  recipientName String
  phoneNumber   String
  isActive      Boolean  @default(true)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentProof {
  id         String   @id @default(cuid())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  fileUrl    String
  uploadedAt DateTime @default(now())
}

model OrderItem {
  id            String       @id @default(cuid())
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  product       Product      @relation(fields: [productId], references: [id])
  productId     String
  productVariant   ProductVariant?     @relation(fields: [productVariantId], references: [id])
  productVariantId String?
  productSize   ProductSize? @relation(fields: [productSizeId], references: [id])
  productSizeId String?
  productVariantSize   ProductVariantSize? @relation(fields: [productVariantSizeId], references: [id])
  productVariantSizeId String?
  // snapshot of product details at purchase time
  productName   String
  variantName   String?
  variantSku    String?
  sizeLabel     String?
  unitPrice     Int
  quantity      Int          @default(1)
}

model ManualSale {
  id                   String             @id @default(cuid())
  product              Product            @relation(fields: [productId], references: [id])
  productId            String
  productVariant       ProductVariant     @relation(fields: [productVariantId], references: [id])
  productVariantId     String
  productVariantSize   ProductVariantSize @relation(fields: [productVariantSizeId], references: [id])
  productVariantSizeId String
  quantity             Int
  amount               Int?
  comment              String?
  saleCategory         String             @default("SALE")
  productName          String
  variantName          String
  sizeLabel            String
  unitCostSnapshot     Int                @default(0)
  createdAt            DateTime           @default(now())
}

model Expense {
  id        String   @id @default(cuid())
  date      DateTime
  category  String
  amount    Int
  comment   String?
  createdAt DateTime @default(now())
}

// Глобальные финансовые настройки (одна запись с id = "default").
model FinanceSettings {
  id              String   @id
  startingBalance Int      @default(0) // копейки
  updatedAt       DateTime @updatedAt
}
