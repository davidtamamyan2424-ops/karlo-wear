# Server
PORT=4000
NODE_ENV=development

# CORS — comma separated list of allowed origins (client dev server, tunnel URL, etc.)
CLIENT_ORIGIN=http://localhost:5173

# Prisma / PostgreSQL
# Local (with docker-compose.yml):  docker compose up -d postgres
DATABASE_URL="postgresql://karlo:karlo@localhost:5432/karlo_wear?schema=public"

# Production example (managed PostgreSQL):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Telegram
# Bot token from @BotFather — used to validate Mini App initData and send order notifications
TELEGRAM_BOT_TOKEN=
# Chat ID that receives new order notifications (admin/group chat)
TELEGRAM_ADMIN_CHAT_ID=

# Admin panel auth (simple shared secret for now)
ADMIN_API_TOKEN=change-me
