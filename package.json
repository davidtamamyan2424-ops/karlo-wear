{
  "name": "karlo-wear",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram Mini App clothing store (React + TS + Tailwind / Node + Express / Prisma + PostgreSQL)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "build:server": "npm run build --workspace server",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client",
    "test": "npm run test --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true,
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
